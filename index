/* SAVE */
async function save(){
if(S.rec&&S.rec.state==='recording')stopR();
await new Promise(r=>setTimeout(r,300));
const now=new Date();const hora=now.toLocaleString('es-CL',{dateStyle:'short',timeStyle:'medium'});
const fn=now.getFullYear()+'-'+pad(now.getMonth()+1)+'-'+pad(now.getDate())+'_'+pad(now.getHours())+'-'+pad(now.getMinutes())+'-'+pad(now.getSeconds())+'.webm';
const rec={action:'register',run:$('vR').value.trim(),nombre:$('vN').value.trim(),sexo:$('vS').value.trim(),
bodega:$('vB').value.trim(),patente:$('vP').value.trim(),observaciones:$('vO').value.trim(),
hora:hora,tieneAudio:S.aB?'si':'no',contacto:S.cN||'',validado:S.val||''};
const btn=$('btnD');btn.disabled=true;btn.textContent='registrando…';
if(!ep()){btn.disabled=false;btn.textContent='✓ realizado — registrar';toast('configure link','!',1);return}
let resp=null,err='';
try{const url=ep()+'?'+new URLSearchParams(rec).toString();const r=await fetch(url,{redirect:'follow'});const txt=await r.text();
try{resp=JSON.parse(txt)}catch(pe){err=txt.slice(0,80)}}catch(e){err=e.message}
if(S.aB&&resp&&resp.ok){try{const b64=await blob64(S.aB);
await fetch(ep(),{method:'POST',headers:{'Content-Type':'text/plain'},body:JSON.stringify({action:'uploadAudio',audio:b64,filename:fn})})}catch(e){}}
S.ct++;$('pill').textContent=S.ct;btn.disabled=false;btn.textContent='✓ realizado — registrar';
if(resp&&resp.ok!==undefined){
  if(resp.blocked||S.val==='no'){showR('block',rec,resp)}
  else showR('ok',rec,resp)}
else toast('error: '+(err||'?'),'!',1)}
function pad(n){return n<10?'0'+n:''+n}
function blob64(b){return new Promise((r,j)=>{const f=new FileReader();f.onloadend=()=>r(f.result.split(',')[1]);f.onerror=j;f.readAsDataURL(b)})}

