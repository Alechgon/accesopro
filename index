<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>Control de Acceso</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/tesseract.js@5.1.1/dist/tesseract.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<style>
:root{
  --bg:#0f1923;--bg2:#162029;--bg3:#1c2a36;--card:rgba(255,255,255,.04);
  --brd:rgba(255,255,255,.07);--accent:#5bb8a6;--accent2:#4ca898;
  --txt:#e8edf2;--txt2:#8a9bb0;--txt3:#506070;
  --ok:#48c78e;--err:#f14668;--warn:#ffe08a;
  --r:12px;--r2:8px;
  --font:'Inter',system-ui,sans-serif;--mono:'JetBrains Mono',monospace;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden}
body{font-family:var(--font);background:var(--bg);color:var(--txt);position:fixed;inset:0}
#app{height:100%;max-width:480px;margin:0 auto;position:relative}
.sc{position:absolute;inset:0;display:none;flex-direction:column}.sc.on{display:flex}
input,select,textarea{font-family:var(--font)}
/* SPLASH */
#splash{background:var(--bg);align-items:center;justify-content:center;z-index:100}
#splash.on{display:flex}
.splash-name{font-size:28px;font-weight:300;letter-spacing:.25em;color:var(--txt2);opacity:0;animation:sIn .8s .3s ease forwards}
.splash-sub{font-size:10px;letter-spacing:.4em;color:var(--txt3);margin-top:8px;opacity:0;animation:sIn .6s .8s ease forwards;text-transform:uppercase}
@keyframes sIn{to{opacity:1}}
/* Buttons */
.bt{border:none;border-radius:var(--r);font-family:var(--font);font-weight:700;font-size:14px;padding:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;transition:all .15s;width:100%}
.bt:active{transform:scale(.97)}.bt:disabled{opacity:.35}
.bp{background:var(--accent);color:var(--bg)}.bp:hover{background:var(--accent2)}
.bs{background:var(--card);color:var(--txt);border:1px solid var(--brd)}.bs:hover{border-color:var(--accent)}
.bd{background:var(--err);color:#fff}
/* Inputs */
.ip{background:var(--card);border:1px solid var(--brd);color:var(--txt);border-radius:var(--r2);padding:10px 12px;font-size:13px;width:100%;text-transform:lowercase}
.ip:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(91,184,166,.15)}
.ip::placeholder{color:var(--txt3);text-transform:none}
.sl{background:var(--card);border:1px solid var(--brd);color:var(--txt);border-radius:var(--r2);padding:10px;font-size:13px;appearance:none;cursor:pointer;text-transform:lowercase}
.sl:focus{outline:none;border-color:var(--accent)}
textarea.ip{resize:vertical;min-height:48px}
/* Cards */
.cd{background:var(--card);border:1px solid var(--brd);border-radius:var(--r);padding:14px;display:flex;flex-direction:column;gap:8px}
.lb{font-family:var(--mono);font-size:9px;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);margin-bottom:2px}
.rw{display:flex;gap:6px;align-items:center}
.lk{font-family:var(--mono);font-size:9px;color:var(--accent);cursor:pointer;text-decoration:underline;text-underline-offset:2px}.lk:active{opacity:.5}
/* Top */
.tp{display:flex;align-items:center;gap:10px;padding:12px 14px;background:var(--bg2);border-bottom:1px solid var(--brd);flex-shrink:0}
.bk{background:var(--card);border:1px solid var(--brd);color:var(--txt);width:34px;height:34px;border-radius:var(--r2);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center}.bk:active{transform:scale(.9)}
.tp h2{font-size:13px;font-weight:700}.tp .ts{font-family:var(--mono);font-size:7px;color:var(--accent);letter-spacing:.14em;text-transform:uppercase}
.pl{font-family:var(--mono);font-size:9px;background:rgba(91,184,166,.1);color:var(--accent);padding:3px 8px;border-radius:12px;margin-left:auto}
/* HOME */
#home{justify-content:space-between;padding:32px 20px 24px;background:linear-gradient(170deg,var(--bg) 0%,var(--bg2) 100%)}
.h-brand{font-size:32px;font-weight:900;letter-spacing:-.02em;line-height:1}
.h-sub{font-size:14px;color:var(--txt2);font-weight:500}
.conn{display:flex;align-items:center;gap:5px;font-family:var(--mono);font-size:8px;color:var(--txt3)}
.dot{width:6px;height:6px;border-radius:50%;background:var(--err)}.dot.ok{background:var(--ok)}
.pb{height:2px;background:rgba(255,255,255,.05);border-radius:2px;overflow:hidden;margin-top:3px}.pb .fl{height:100%;background:var(--accent);width:0%;transition:width .3s}
/* SCROLL BODY */
.body{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:12px;-webkit-overflow-scrolling:touch}
/* SCAN BTN */
.scan-wrap{display:flex;border-radius:var(--r);overflow:hidden;border:1px solid var(--brd)}
.scan-half{flex:1;padding:18px 10px;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:4px;font-weight:800;font-size:13px;transition:all .15s;border:none}
.scan-half:active{transform:scale(.97)}
.scan-ced{background:var(--accent);color:var(--bg)}
.scan-pas{background:#4a7fb5;color:#fff}
.scan-half small{font-weight:400;font-size:9px;opacity:.7}
/* VERIFY INLINE PROHIBITION */
.proh-bar{background:rgba(241,70,104,.1);border:1px solid rgba(241,70,104,.3);border-radius:var(--r2);padding:10px 12px;display:none;align-items:center;gap:8px}
.proh-bar.show{display:flex}
.proh-bar .proh-txt{flex:1;font-size:11px;color:var(--err);font-weight:700}
.proh-bar .proh-btn{background:var(--err);color:#fff;border:none;border-radius:var(--r2);padding:6px 10px;font-size:10px;font-weight:700;cursor:pointer;white-space:nowrap}
/* AUTOCOMPLETE */
.ac-wrap{position:relative}
.ac-list{position:absolute;top:100%;left:0;right:0;background:var(--bg2);border:1px solid var(--brd);border-radius:0 0 var(--r2) var(--r2);max-height:120px;overflow-y:auto;z-index:10;display:none}
.ac-list.show{display:block}
.ac-item{padding:8px 10px;font-size:12px;cursor:pointer;border-bottom:1px solid var(--brd);text-transform:lowercase}.ac-item:hover,.ac-item.hl{background:rgba(91,184,166,.1);color:var(--accent)}
/* CALL */
.csec{background:var(--card);border:1px solid var(--brd);border-radius:var(--r);padding:12px;display:flex;flex-direction:column;gap:8px}
.cb{width:40px;height:40px;border:none;border-radius:var(--r2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;background:#4a7fb5;color:#fff}.cb:active{transform:scale(.9)}
.ri{font-family:var(--mono);font-size:9px;color:var(--err);display:none;align-items:center;gap:5px}
.ri.show{display:flex}
.rdot{width:6px;height:6px;border-radius:50%;background:var(--err);animation:bl 1s infinite}
@keyframes bl{50%{opacity:.2}}
.ap{width:100%;border-radius:6px;margin-top:2px}
/* RESULT */
.rs{position:fixed;inset:0;z-index:70;display:none;flex-direction:column;align-items:center;justify-content:center;padding:24px;text-align:center}.rs.show{display:flex}
.rs.ok{background:linear-gradient(160deg,#1a3a2a,#0f1923)}.rs.block{background:linear-gradient(160deg,#3a1a1a,#1a0f0f)}
.rs .bi{font-size:64px;margin-bottom:6px}.rs h1{font-size:24px;font-weight:900;margin-bottom:6px}
.rs p{font-size:12px;color:var(--txt2);max-width:260px;line-height:1.3}
.rs .wh{font-family:var(--mono);font-size:10px;margin-top:8px;background:rgba(255,255,255,.06);padding:8px 12px;border-radius:var(--r2)}
.rs .bt{margin-top:20px;width:auto;min-width:150px}
.rs.block .bt{background:#fff;color:var(--err)}.rs.ok .bt{background:var(--ok);color:var(--bg)}
/* MODALS */
.mb{position:fixed;inset:0;background:rgba(0,0,0,.7);display:none;align-items:center;justify-content:center;z-index:60;padding:14px;overflow-y:auto}.mb.show{display:flex}
.md{background:var(--bg2);border:1px solid var(--brd);border-radius:var(--r);padding:16px;width:100%;max-width:380px;display:flex;flex-direction:column;gap:8px;max-height:88vh;overflow-y:auto}
.md h3{font-size:14px}.md label{font-family:var(--mono);font-size:7px;color:var(--accent);letter-spacing:.1em;text-transform:uppercase}
.md small{color:var(--txt3);font-size:8px;line-height:1.3}
.md hr{border:none;border-top:1px solid var(--brd)}
.clist{max-height:140px;overflow-y:auto;display:flex;flex-direction:column;gap:2px}
.ci{display:flex;align-items:center;gap:5px;padding:5px 7px;background:var(--card);border-radius:var(--r2);font-size:9px}
.ci .cn{flex:1;font-weight:600}.ci .ct{font-family:var(--mono);font-size:8px;color:var(--txt2)}.ci .cb2{font-size:8px;color:var(--accent)}
.cdel{background:none;border:none;color:var(--err);cursor:pointer;font-size:12px;padding:1px}
/* CALL CONFIRM */
.cc{position:fixed;inset:0;background:rgba(0,0,0,.8);display:none;align-items:center;justify-content:center;z-index:65;padding:16px}.cc.show{display:flex}
.ccb{background:var(--bg2);border:1px solid var(--brd);border-radius:var(--r);padding:20px;width:100%;max-width:340px;text-align:center;display:flex;flex-direction:column;gap:10px}
.ccb .wi{font-size:36px}.ccb h3{font-size:15px}.ccb p{font-size:11px;color:var(--txt2);line-height:1.3}
.to{position:fixed;left:50%;bottom:20px;transform:translateX(-50%) translateY(120px);background:#fff;color:var(--bg);font-weight:700;padding:10px 16px;border-radius:var(--r2);box-shadow:0 6px 24px rgba(0,0,0,.4);transition:transform .3s cubic-bezier(.2,1.2,.3,1);z-index:80;display:flex;align-items:center;gap:5px;font-size:11px;max-width:84%}.to.show{transform:translateX(-50%) translateY(0)}.to.err{background:var(--err);color:#fff}
.cr{position:fixed;right:8px;bottom:4px;font-family:var(--mono);font-size:6px;color:var(--txt3);z-index:5}
</style>
</head>
<body>
<div id="app">
<!-- SPLASH -->
<section id="splash" class="sc on"><div class="splash-name">alechgon</div><div class="splash-sub">security systems</div></section>

<!-- HOME -->
<section id="home" class="sc">
<div><div class="h-brand">Control de<br>Acceso</div><div style="height:6px"></div><div class="h-sub">Sistema de registro de ingresos</div></div>
<div style="margin-top:auto;display:flex;flex-direction:column;gap:8px">
<button class="bt bp" onclick="goId()">Ingreso</button>
<button class="bt bs" onclick="askP()">Configuración</button>
<div class="conn"><span class="dot" id="cfD"></span><span id="cfT">—</span></div>
<div class="pb" id="oBar"><div class="fl" id="oFl"></div></div>
<div class="conn" id="oTx">preparando ocr…</div>
</div></section>

<!-- IDENTIFY -->
<section id="identify" class="sc">
<div class="tp"><button class="bk" onclick="goHome()">‹</button><div><h2>Nuevo ingreso</h2><div class="ts">identificación</div></div><span class="pl" id="pill">0</span></div>
<div class="body">
<div class="cd"><div class="lb">ubicación</div>
<div class="rw"><select class="sl" id="bL" onchange="bodCh()" style="flex:1"><option value="">torre…</option></select></div>
<div class="ac-wrap"><input class="ip" id="bD" placeholder="depto / oficina" oninput="acDept()" onfocus="acDept()" autocomplete="off"><div class="ac-list" id="acD"></div></div></div>

<div class="cd" id="patSec" style="display:none"><div class="lb">patente</div>
<div id="pCl"><div class="rw"><input class="ip" style="width:44px;text-align:center" id="p1" maxlength="2" oninput="pAu(this,'p2')"><span style="color:var(--txt3)">·</span><input class="ip" style="width:44px;text-align:center" id="p2" maxlength="2" oninput="pAu(this,'p3')"><span style="color:var(--txt3)">·</span><input class="ip" style="width:44px;text-align:center" id="p3" maxlength="2" oninput="ckSr()"></div></div>
<div id="pIn" style="display:none"><input class="ip" id="pI" placeholder="patente internacional" oninput="ckSr()"></div>
<div class="rw" style="gap:12px"><span class="lk" onclick="tgPat()" id="pTg">internacional</span><span class="lk" onclick="tgMoto()">moto</span></div></div>
<span class="lk" id="patLk" onclick="showPat()" style="text-align:center;display:block">+ agregar patente (opcional)</span>

<div class="scan-wrap"><button class="scan-half scan-ced" onclick="goScan('ced')">📇<span>cédula</span><small>reverso · mrz</small></button><button class="scan-half scan-pas" onclick="goScan('pas')">📘<span>pasaporte</span><small>página datos · mrz</small></button></div>
<span class="lk" style="text-align:center" onclick="goMan()">ingreso manual</span>
<div class="orl" style="font-family:var(--mono);font-size:7px;color:var(--txt3);text-align:center;letter-spacing:.15em">— o busca por patente —</div>
<button class="bt bs" id="btnSr" onclick="srPat()" style="display:none;font-size:12px">buscar por patente</button>
</div></section>

<!-- SCAN -->
<section id="scan" class="sc">
<div class="tp"><button class="bk" onclick="goId2()">‹</button><div><h2 id="scanTitle">escanear cédula</h2><div class="ts" id="scanSub">mrz · reverso</div></div></div>
<div style="position:relative;flex:1;overflow:hidden;background:#000"><video id="vid" playsinline muted style="width:100%;height:100%;object-fit:cover"></video><div class="fr" style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:88%;aspect-ratio:1.586;border-radius:8px;box-shadow:0 0 0 4000px rgba(0,0,0,.55);border:1.5px solid rgba(255,255,255,.3)"><div style="position:absolute;left:3%;right:3%;bottom:4%;height:30%;border:1.5px dashed var(--accent);border-radius:5px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:7px;color:var(--accent);letter-spacing:.08em;background:rgba(91,184,166,.04)" id="scanGuide">alinea las líneas &lt;&lt;&lt; aquí</div></div></div>
<div style="padding:12px 14px 18px;background:var(--bg2);display:flex;flex-direction:column;gap:7px"><div class="stx" id="sSt" style="font-family:var(--mono);font-size:9px;color:var(--txt2);text-align:center">cámara lista</div><button class="bt bp" onclick="cap()">capturar</button></div></section>

<!-- MANUAL -->
<section id="manual" class="sc">
<div class="tp"><button class="bk" onclick="goId2()">‹</button><div><h2>ingreso manual</h2><div class="ts">escriba los datos</div></div></div>
<div class="body">
<div class="cd"><div class="lb">run / n° pasaporte</div><input class="ip" id="mR" placeholder="12.345.678-9"></div>
<div class="cd"><div class="lb">nombre completo</div><input class="ip" id="mN" placeholder="nombre y apellidos"></div>
<div class="cd"><div class="lb">sexo</div><div class="rw" style="gap:4px"><button class="bt bs" style="flex:1;padding:10px;font-size:12px" onclick="pSx(this,'m')" id="sxM">masculino</button><button class="bt bs" style="flex:1;padding:10px;font-size:12px" onclick="pSx(this,'f')" id="sxF">femenino</button></div></div>
<button class="bt bp" style="margin-top:auto" onclick="mCont()">continuar</button></div></section>

<!-- VERIFY -->
<section id="verify" class="sc">
<div class="tp"><button class="bk" onclick="goId2()">‹</button><div><h2>verificar datos</h2><div class="ts">confirma y registra</div></div></div>
<div class="body">
<div class="proh-bar" id="prohBar"><span style="font-size:16px">⛔</span><span class="proh-txt" id="prohTxt">prohibición de ingreso</span><button class="proh-btn" onclick="showProh()">ver detalle</button></div>
<div class="cd" style="gap:6px">
<div><div class="lb">run</div><input class="ip" id="vR"></div>
<div><div class="lb">nombre</div><input class="ip" id="vN"></div>
<div><div class="lb">sexo</div><input class="ip" id="vS"></div>
<div><div class="lb">empresa</div><input class="ip" id="vE" readonly style="color:var(--txt2)"></div>
<div><div class="lb">torre / depto</div><input class="ip" id="vB" readonly style="color:var(--txt2)"></div>
<div><div class="lb">patente</div><input class="ip" id="vP" readonly style="color:var(--txt2)"></div>
<div><div class="lb">observaciones</div><textarea class="ip" id="vO" placeholder="proveedor, visita, empresa…"></textarea></div>
</div>
<div class="csec">
<div class="lb">contacto / autorización</div>
<div class="rw"><select class="sl" id="cSel" onchange="cSelC()" style="flex:1"><option value="">— contacto —</option></select></div>
<div class="rw"><input class="ip" id="cPh" placeholder="teléfono" inputmode="tel" style="flex:1"><button class="cb" onclick="initCall()">📞</button></div>
<div class="ri" id="recI"><span class="rdot"></span><span id="rTm">0s</span><span>grabando</span><button class="bt bd" style="padding:5px 10px;font-size:10px;width:auto" onclick="stopR()">detener</button></div>
<div id="rPl"></div>
<div style="font-family:var(--mono);font-size:7px;color:var(--txt3)">la llamada se graba automáticamente</div>
</div>
<div class="cd"><div class="lb">¿ingreso validado por residente?</div>
<div class="rw" style="gap:4px"><button class="bt bs" style="flex:1;padding:10px;font-size:12px" onclick="pVal(this,'si')" id="valS">sí</button><button class="bt bs" style="flex:1;padding:10px;font-size:12px" onclick="pVal(this,'no')" id="valN">no</button></div></div>
<button class="bt bp" style="font-size:16px;padding:16px" id="btnD" onclick="save()">✓ realizado — registrar</button>
<button class="bt bs" onclick="goId2()">volver</button>
</div></section>

<div class="cr">v1.0 · alechgon</div>
</div>

<!-- RESULT -->
<div class="rs" id="res"><div class="bi" id="rI">✓</div><h1 id="rT">ok</h1><p id="rM"></p><div class="wh" id="rW"></div><button class="bt" onclick="clRes()">continuar</button></div>
<!-- CALL CONFIRM -->
<div class="cc" id="callC"><div class="ccb"><div class="wi">📞</div><h3>llamada con grabación</h3><p>se grabará el audio por seguridad. al aceptar se iniciará la grabación y la llamada.</p><p id="ccTo" style="font-weight:700;color:var(--accent)"></p><button class="bt bp" onclick="cfmCall()">aceptar y llamar</button><button class="bt bs" onclick="cnlCall()">cancelar</button></div></div>
<!-- PASS -->
<div class="mb" id="pMod"><div class="md"><h3>configuración</h3><label>contraseña</label><input id="pIn2" type="password" class="ip" inputmode="numeric" placeholder="••••••••"><div style="color:var(--err);font-size:9px;min-height:10px" id="pEr"></div><button class="bt bp" onclick="ckP()">entrar</button><button class="bt bs" onclick="clP()">cancelar</button></div></div>
<!-- CFG -->
<div class="mb" id="cMod"><div class="md" style="gap:7px">
<h3>conexión</h3><label>link actual</label><div style="background:var(--card);border:1px solid var(--brd);border-radius:var(--r2);padding:7px;font-family:var(--mono);font-size:7px;word-break:break-all;color:var(--txt2)" id="cLk">—</div>
<label>nuevo link</label><input class="ip" id="cIn" placeholder="https://script.google.com/.../exec">
<button class="bt bp" style="padding:8px;font-size:11px" onclick="svLk()">guardar</button>
<button class="bt bs" style="padding:6px;font-size:10px" onclick="testEp()">probar conexión</button>
<div style="font-size:9px;min-height:10px;color:var(--txt2)" id="tRes"></div>
<hr>
<h3>estructura del edificio</h3>
<div class="rw"><input class="ip" id="cfTw" placeholder="nombre o n° de torre"><button class="bt bp" style="padding:8px;font-size:10px;width:auto;white-space:nowrap" onclick="cfAddTw()">+ torre</button></div>
<div id="cfTwList" class="clist"></div>
<hr>
<h3>contactos</h3><small>vinculados a la estructura del edificio</small>
<div class="rw"><select class="sl" id="cfCT" style="flex:1"><option value="">torre…</option></select><input class="ip" id="cfCD" placeholder="depto" style="width:60px"></div>
<button class="bt bs" style="padding:6px;font-size:10px" onclick="cfFilt()">ver contactos</button>
<div class="clist" id="cfCList"></div>
<label>agregar contacto</label>
<input class="ip" id="cfCN" placeholder="nombre"><input class="ip" id="cfCTl" placeholder="teléfono" inputmode="tel">
<button class="bt bp" style="padding:8px;font-size:10px" onclick="cfAddC()">+ agregar</button>
<hr>
<label>importar excel</label><small>contactos: A=torre B=depto C=nombre D=teléfono</small>
<input type="file" id="cfFl" accept=".xlsx,.xls" onchange="cfImp(this)" style="font-size:9px">
<button class="bt bs" style="padding:6px;font-size:9px" onclick="cfClrC()">eliminar todos los contactos</button>
<hr><button class="bt bs" onclick="clC()">cerrar</button>
</div></div>
<div class="to" id="to"><span id="tI">✓</span><span id="tM"></span></div>

<script>
const DE="";
const CP="123456789";
const S={ov:null,ct:0,str:null,oW:null,oR:false,iP:false,mSx:'',scanMode:'ced',
  rec:null,ch:[],rT:null,rS:0,aB:null,aU:null,cN:'',val:'',
  towers:[],depts:{},contacts:[]};
