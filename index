/* OCR */
async function cap(){const v=$('vid');if(!v.videoWidth||!S.oR){$('sSt').textContent='ocr no listo';return}
$('sSt').textContent='leyendo mrz…';
const vw=v.videoWidth,vh=v.videoHeight,c=document.createElement('canvas');
const cy=Math.floor(vh*.46),ch=Math.floor(vh*.52),cx=Math.floor(vw*.02),cw=Math.floor(vw*.96);
c.width=cw;c.height=ch;const ctx=c.getContext('2d');ctx.drawImage(v,cx,cy,cw,ch,0,0,cw,ch);
const img=ctx.getImageData(0,0,cw,ch),d=img.data;
for(let i=0;i<d.length;i+=4){let g=.299*d[i]+.587*d[i+1]+.114*d[i+2];g=g>125?255:(g<85?0:g);d[i]=d[i+1]=d[i+2]=g}
ctx.putImageData(img,0,0);
try{const{data}=await S.oW.recognize(c);const p=S.scanMode==='pas'?parseTD3(data.text):parseTD1(data.text);
if(!p){const pAlt=S.scanMode==='pas'?parseTD1(data.text):parseTD3(data.text);if(pAlt){fV(pAlt);stopC();sh('verify');return}}
if(p){if(!bVal())return;fV(p);stopC();sh('verify')}else $('sSt').textContent='mrz no detectada, reintenta'}catch(e){$('sSt').textContent='error: '+e.message}}

/* TD1 PARSER (cédulas) */
function parseTD1(raw){
let ls=raw.toUpperCase().split('\n').map(l=>l.replace(/[^A-Z0-9<]/g,'').trim()).filter(l=>l.length>=20);
if(ls.length<2)return null;
const cD=s=>(s.match(/\d/g)||[]).length,cL=s=>(s.match(/[A-Z]/g)||[]).length;
let lD=null,lC=null,lN=null,bD=-1;
for(const l of ls){const d=cD(l);if(/CHL/.test(l)&&d>=11&&d>bD){bD=d;lD=l}}
for(const l of ls){if(l===lD)continue;if(/^I.{0,2}CHL/.test(l)||/^I</.test(l)){lC=l;break}}
let bN=-1;for(const l of ls){if(l===lD||l===lC)continue;const t=cL(l);if(t>=4&&t>cD(l)&&/</.test(l)&&t>bN){bN=t;lN=l}}
if(!lN){for(const l of ls){if(l!==lD&&l!==lC){const t=cL(l);if(t>bN){bN=t;lN=l}}}}
const r={run:'',nombre:'',sexo:'',nacionalidad:'chilena'};
if(lN){const p=lN.split('<<');r.nombre=((p[1]||'').replace(/</g,' ').trim()+' '+(p[0]||'').replace(/</g,' ').trim()).replace(/\s+/g,' ').trim().toLowerCase()}
if(lD){const sx=lD.match(/\d([MF])\d/);if(sx)r.sexo=sx[1]==='M'?'masculino':'femenino';
const i=lD.indexOf('CHL');if(i!==-1){const rest=lD.slice(i+3),cut=rest.indexOf('<');let b='',dv='';
if(cut!==-1){b=rest.slice(0,cut).replace(/[^0-9K]/g,'');const af=rest.slice(cut).replace(/</g,'');dv=(af.charAt(0)||'').replace(/[^0-9K]/g,'')}
else{const m=rest.match(/(\d{7,8})([0-9K])/);if(m){b=m[1];dv=m[2]}}
if(b&&dv)r.run=fmtRun(b,dv)}}
return(!r.nombre&&!r.run)?null:r}

/* TD3 PARSER (pasaportes) */
function parseTD3(raw){
let ls=raw.toUpperCase().split('\n').map(l=>l.replace(/[^A-Z0-9<]/g,'').trim()).filter(l=>l.length>=30);
if(ls.length<2)return null;
let lName=null,lData=null;
for(const l of ls){if(/^P/.test(l)&&(l.match(/[A-Z]/g)||[]).length>10){lName=l;break}}
for(const l of ls){if(l===lName)continue;if((l.match(/\d/g)||[]).length>=10){lData=l;break}}
if(!lName||!lData)return null;
const r={run:'',nombre:'',sexo:'',nacionalidad:''};
const nPart=lName.slice(5);const pts=nPart.split('<<');
r.nombre=((pts[1]||'').replace(/</g,' ').trim()+' '+(pts[0]||'').replace(/</g,' ').trim()).replace(/\s+/g,' ').trim().toLowerCase();
const nat=lName.slice(2,5).replace(/</g,'');r.nacionalidad=nat.toLowerCase();
if(lData.length>=44){r.run=lData.slice(0,9).replace(/</g,'').toLowerCase();
const sx=lData.charAt(20);r.sexo=sx==='M'?'masculino':(sx==='F'?'femenino':'')}
return(!r.nombre&&!r.run)?null:r}

function fmtRun(b,d){let c=b.split('').reverse().join(''),o='';for(let i=0;i<c.length;i++){o+=c[i];if((i+1)%3===0&&i!==c.length-1)o+='.'}return o.split('').reverse().join('')+'-'+d}

